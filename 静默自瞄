local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local GetPlayers = Players.GetPlayers
local GetMouseLocation = UserInputService.GetMouseLocation
local FindFirstChild = game.FindFirstChild
local WorldToScreen = Camera.WorldToScreenPoint
local GetPartsObscuringTarget = Camera.GetPartsObscuringTarget
local ValidTargetParts = {"Head", "HumanoidRootPart"}

local IsMobile = UserInputService.TouchEnabled and not UserInputService.MouseEnabled

local fovCircle
local fovFrame
local fovGui

if IsMobile then
    fovGui = Instance.new("ScreenGui")
    fovGui.Parent = game:GetService("CoreGui")
    fovGui.ResetOnSpawn = false
    fovGui.IgnoreGuiInset = true

    fovFrame = Instance.new("Frame")
    fovFrame.Parent = fovGui
    fovFrame.Size = UDim2.new(0, SilentAimSettings.FOVRadius * 2, 0, SilentAimSettings.FOVRadius * 2)
    fovFrame.Position = UDim2.new(0.5, -SilentAimSettings.FOVRadius, 0.5, -SilentAimSettings.FOVRadius)
    fovFrame.BackgroundTransparency = 1
    fovFrame.Visible = false
    fovFrame.ZIndex = 999

    local corner = Instance.new("UICorner")
    corner.Parent = fovFrame
    corner.CornerRadius = UDim.new(1, 0)

    local stroke = Instance.new("UIStroke")
    stroke.Parent = fovFrame
    stroke.Color = Color3.fromRGB(255, 50, 50)
    stroke.Thickness = 1
    stroke.Transparency = 0

    fovCircle = {
        Visible = false,
        Radius = SilentAimSettings.FOVRadius,
        Position = Vector2.new(0, 0),
    }
    function fovCircle:setVisible(v)
        self.Visible = v
        fovFrame.Visible = v
    end
    function fovCircle:setRadius(r)
        self.Radius = r
        fovFrame.Size = UDim2.new(0, r * 2, 0, r * 2)
        fovFrame.Position = UDim2.new(0.5, -r, 0.5, -r)
    end
    function fovCircle:setPosition(pos)
        self.Position = pos
    end
else
    fovCircle = Drawing.new("Circle")
    fovCircle.Thickness = 1
    fovCircle.NumSides = 100
    fovCircle.Radius = SilentAimSettings.FOVRadius
    fovCircle.Filled = false
    fovCircle.Visible = false
    fovCircle.Transparency = 1
    fovCircle.Color = Color3.fromRGB(255, 50, 50)
end

function CalculateChance(Percentage)
    Percentage = math.floor(Percentage)
    return math.random() <= Percentage / 100
end

local function getPositionOnScreen(Vector)
    local Vec3, OnScreen = WorldToScreen(Camera, Vector)
    return Vector2.new(Vec3.X, Vec3.Y), OnScreen
end

local function getDirection(Origin, Position)
    return (Position - Origin).Unit * 1000
end

local function getMousePosition()
    if IsMobile then
        local ViewportSize = Camera.ViewportSize
        return Vector2.new(ViewportSize.X / 2, ViewportSize.Y / 2)
    end
    return GetMouseLocation(UserInputService)
end

local function getClosestPlayer()
    if not SilentAimSettings.TargetPart then
        return nil
    end
    local Closest = nil
    local DistanceToMouse = nil
    local players = GetPlayers(Players)
    for i = 1, #players do
        local Player = players[i]
        if Player == LocalPlayer then
        elseif SilentAimSettings.TeamCheck and Player.Team == LocalPlayer.Team then
        else
            local Character = Player.Character
            if Character then
                local HumanoidRootPart = FindFirstChild(Character, "HumanoidRootPart")
                local Humanoid = FindFirstChild(Character, "Humanoid")
                if HumanoidRootPart and Humanoid and Humanoid.Health > 0 then
                    local ScreenPosition, OnScreen = getPositionOnScreen(HumanoidRootPart.Position)
                    if OnScreen then
                        local Distance = (getMousePosition() - ScreenPosition).Magnitude
                        local maxDist = DistanceToMouse or SilentAimSettings.FOVRadius
                        if Distance <= maxDist then
                            if SilentAimSettings.TargetPart == "Random" then
                                local randomIndex = math.random(1, #ValidTargetParts)
                                Closest = Character[ValidTargetParts[randomIndex]]
                            else
                                local targetPart = Character[SilentAimSettings.TargetPart]
                                if not targetPart then
                                    targetPart = Character["HumanoidRootPart"]
                                end
                                Closest = targetPart
                            end
                            DistanceToMouse = Distance
                        end
                    end
                end
            end
        end
    end
    return Closest
end

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(...)
    local Method = getnamecallmethod()
    local Arguments = {...}
    local self = Arguments[1]
    local chance = CalculateChance(SilentAimSettings.HitChance)

    if SilentAimSettings.Enabled and self == workspace and not checkcaller() and chance == true then
        if Method == "Raycast" and SilentAimSettings.SilentAimMethod == Method then
            local A_Origin = Arguments[2]
            local HitPart = getClosestPlayer()
            if HitPart then
                Arguments[3] = getDirection(A_Origin, HitPart.Position)
                return oldNamecall(unpack(Arguments))
            end
        end
    end
    return oldNamecall(...)
end))

local renderConnection
renderConnection = RunService.RenderStepped:Connect(function()
    if SilentAimSettings.Enabled then
        if IsMobile then
            fovFrame.Visible = true
            fovFrame.Size = UDim2.new(0, SilentAimSettings.FOVRadius * 2, 0, SilentAimSettings.FOVRadius * 2)
            fovFrame.Position = UDim2.new(0.5, -SilentAimSettings.FOVRadius, 0.5, -SilentAimSettings.FOVRadius)
        else
            fovCircle.Position = getMousePosition()
            fovCircle.Radius = SilentAimSettings.FOVRadius
            fovCircle.Visible = true
        end
    else
        if IsMobile then
            fovFrame.Visible = false
        else
            fovCircle.Visible = false
        end
    end
end)

