local SilentAimSettings = {
    Enabled = false,
    TeamCheck = false,
    TargetPart = "HumanoidRootPart",
    SilentAimMethod = "Raycast",
    FOVRadius = 130,
    HitChance = 100,
}

local Camera = workspace.CurrentCamera
